# Copy to .env and fill in. Never commit .env.
# These values live in n8n credentials, not loaded by code directly — .env is here as documentation.

# --- Telegram ---
# Get from @BotFather: /newbot
TELEGRAM_BOT_TOKEN=123456789:AA...your-token-here
# Your numeric Telegram user ID (whitelist — bot ignores everyone else).
# Find via @userinfobot
TELEGRAM_ALLOWED_USER_ID=000000000

# --- Supabase ---
# From: project dashboard → Settings → API
SUPABASE_URL=https://your-ref.supabase.co
# service_role key (n8n only, never expose to frontend)
SUPABASE_SERVICE_KEY=eyJ...
# Direct Postgres connection (Supabase → Settings → Database → Connection string → URI)
SUPABASE_POSTGRES_URL=postgresql://postgres:[password]@db.your-ref.supabase.co:5432/postgres

# --- Gemini ---
# Google AI Studio: https://aistudio.google.com/apikey  (BILLING OFF for free tier)
GEMINI_API_KEY=AIza...

# --- Obsidian vault ---
# Absolute path on the n8n host (homelab) where markdown files get written.
# Folder must be Syncthing/iCloud-synced to your Mac for Obsidian to see it.
OBSIDIAN_VAULT_PATH=/home/user/obsidian-vault/n8n-bookmarks
